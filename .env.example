# =============================================================================
# Football Analytics — Variáveis de Ambiente
# Copie para .env e preencha com seus valores reais.
# =============================================================================

# Football-Data.org API
FOOTBALL_DATA_API_KEY=seu_token_aqui

# Google Cloud / BigQuery
GCP_PROJECT_ID=seu-projeto-gcp
BIGQUERY_DATASET_RAW=raw
BIGQUERY_LOCATION=US

# Caminho para service account (opcional — se usar oauth, não precisa)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# dbt
DBT_BIGQUERY_PROJECT=seu-projeto-gcp
